# 创建 .gitignore 文件
echo "# Java" > .gitignore
echo "target/" >> .gitignore
echo "*.class" >> .gitignore
echo "*.log" >> .gitignore
echo "" >> .gitignore
echo "# IDE" >> .gitignore
echo ".idea/" >> .gitignore
echo "*.iml" >> .gitignore
echo ".vscode/" >> .gitignore
echo "" >> .gitignore
echo "# Application" >> .gitignore
echo "application-dev.yml" >> .gitignore
echo "application-prod.yml" >> .gitignore
echo ".env" >> .gitignore
echo "" >> .gitignore
echo "# System" >> .gitignore
echo ".DS_Store" >> .gitignore
echo "Thumbs.db" >> .gitignore